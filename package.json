{
  "name": "crosscheck",
  "version": "0.1.0",
  "description": "Cross-vendor AI code review orchestrator — Claude Code ↔ Codex",
  "bin": {
    "crosscheck": "./dist/cli.js"
  },
  "type": "module",
  "files": [
    "dist",
    "crosscheck.config.example.yml",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "js-yaml": "^4.1.0",
    "octokit": "^4.0.2",
    "ora": "^8.1.0",
    "zod": "^3.23.8",
    "smee-client": "^2.0.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
