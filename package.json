{
  "name": "@humanbased/crosscheck",
  "version": "1.0.0",
  "description": "AI code review pipeline that turns agent-written PRs into merge-ready patches",
  "bin": {
    "crosscheck": "dist/cli.js",
    "ck": "dist/ck.js"
  },
  "type": "module",
  "files": [
    "dist",
    "crosscheck.config.example.yml",
    "AGENT.md",
    "ISSUE.md",
    "README.md",
    "README.zh.md",
    "get-started.md",
    "get-started.zh.md",
    "docs/fixture-pr.md",
    "docs/proof-demo.md",
    "assets"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js dist/ck.js",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "js-yaml": "^4.1.0",
    "octokit": "^4.0.2",
    "ora": "^8.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "ai-code-review",
    "code-review",
    "ai",
    "ai-agents",
    "agentic-coding",
    "claude",
    "claude-code",
    "codex",
    "codex-cli",
    "github",
    "pull-request",
    "review-bot",
    "code-quality",
    "automation",
    "cli"
  ],
  "homepage": "https://github.com/humanbased-ai/crosscheck",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/humanbased-ai/crosscheck.git"
  },
  "bugs": {
    "url": "https://github.com/humanbased-ai/crosscheck/issues"
  },
  "author": "Humanbased PTE LTD",
  "license": "MIT"
}
